generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum Status {
  STARTED
  SUBMITTED
  EXPIRED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum Language {
  EN
  HI
}

//
// CORE ENTITIES
//

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  image         String?
  role          Role       @default(STUDENT)
  status        UserStatus @default(ACTIVE)
  preferredLang Language   @default(EN)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  attempts      Attempt[]
  leaderboard   LeaderboardEntry[]
  subscriptions Subscription[]
  topicStats    UserTopicStat[]
  payments      Payment[]

  @@index([role])
}

model Category {
  id       String  @id @default(cuid())
  name     String
  parentId String?
  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: Restrict)
  children Category[] @relation("SubCategories")
  exams    Exam[]

  @@index([parentId])
}

model Exam {
  id         String  @id @default(cuid())
  name       String
  categoryId String
  isActive   Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  category   Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  planAccess PlanAccess[]
  testSeries TestSeries[]

  @@index([categoryId])
}

model TestSeries {
  id       String  @id @default(cuid())
  title    String
  examId   String
  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  exam       Exam         @relation(fields: [examId], references: [id], onDelete: Restrict)
  tests      Test[]
  planAccess PlanAccess[]

  @@index([examId])
}

//
// SYLLABUS HIERARCHY (GLOBAL SUBJECTS)
//

model Subject {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  topics Topic[]
}

model Topic {
  id        String  @id @default(cuid())
  name      String
  subjectId String
  parentId  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  subject  Subject @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  parent   Topic?  @relation("SubTopics", fields: [parentId], references: [id], onDelete: Restrict)
  children Topic[] @relation("SubTopics")

  questions Question[]
  userStats UserTopicStat[]

  @@unique([subjectId, name]) // Prevent duplicate topic under same subject
  @@index([subjectId])
  @@index([parentId])
}

//
// QUESTION BANK (STRICT)
//

model Question {
  id       String  @id @default(cuid())
  topicId  String
  isActive Boolean @default(true)
  hash     String  @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  topic          Topic                 @relation(fields: [topicId], references: [id], onDelete: Restrict)
  options        QuestionOption[]
  translations   QuestionTranslation[]
  sectionLinks   SectionQuestion[]
  attemptAnswers AttemptAnswer[]

  @@index([topicId])
}

model QuestionTranslation {
  id          String   @id @default(cuid())
  questionId  String
  lang        Language
  content     String
  explanation String?
  imageUrl    String?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, lang])
  @@index([lang])
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  isCorrect  Boolean @default(false)
  order      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  question     Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)
  translations OptionTranslation[]
  answers      AttemptAnswer[]

  @@unique([questionId, order])
  @@index([questionId])
}

model OptionTranslation {
  id       String   @id @default(cuid())
  optionId String
  lang     Language
  text     String

  option QuestionOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, lang])
}

//
// TEST EXECUTION
//

model Test {
  id           String @id @default(cuid())
  title        String
  durationMins Int
  totalMarks   Float
  passMarks    Float
  positiveMark Float  @default(1.0)
  negativeMark Float  @default(0.33)

  startAt     DateTime?
  endAt       DateTime?
  isLive      Boolean   @default(false)
  isPremium   Boolean   @default(false)
  maxAttempts Int?
  isActive    Boolean   @default(true)

  seriesId String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  series      TestSeries         @relation(fields: [seriesId], references: [id], onDelete: Restrict)
  sections    Section[]
  attempts    Attempt[]
  leaderboard LeaderboardEntry[]

  @@index([seriesId])
  @@index([isActive, isLive])
  @@index([startAt])
}

model Section {
  id           String @id @default(cuid())
  testId       String
  name         String
  durationMins Int?
  order        Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  test      Test              @relation(fields: [testId], references: [id], onDelete: Cascade)
  questions SectionQuestion[]

  @@index([testId])
}

model SectionQuestion {
  sectionId  String
  questionId String
  order      Int

  section  Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@id([sectionId, questionId])
  @@index([questionId])
}

//
// HIGH-VOLUME TABLES
//

model Attempt {
  id            BigInt @id @default(autoincrement())
  userId        String
  testId        String
  attemptNumber Int    @default(1)
  status        Status @default(STARTED)

  startTime DateTime  @default(now())
  endTime   DateTime?

  ipAddress       String?
  userAgent       String?
  deviceInfo      String?
  suspiciousScore Float   @default(0)

  score            Float  @default(0)
  correctCount     Int    @default(0)
  wrongCount       Int    @default(0)
  unattemptedCount Int    @default(0)
  accuracy         Float?
  timeTaken        Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  test Test @relation(fields: [testId], references: [id], onDelete: Restrict)

  answers AttemptAnswer[]

  @@unique([userId, testId, attemptNumber])
  @@index([status])
  @@index([testId, createdAt])
  @@index([userId, createdAt])
  @@index([userId, testId])
}

model AttemptAnswer {
  attemptId  BigInt
  questionId String
  optionId   String?

  isCorrect    Boolean @default(false)
  marksAwarded Float?
  isMarked     Boolean @default(false)

  answeredAt DateTime?
  createdAt  DateTime  @default(now())

  attempt  Attempt         @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question        @relation(fields: [questionId], references: [id], onDelete: Restrict)
  option   QuestionOption? @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@id([attemptId, questionId])
  @@index([questionId])
  @@index([optionId])
  @@index([attemptId])
}

model LeaderboardEntry {
  id        BigInt   @id @default(autoincrement())
  testId    String
  userId    String
  score     Float
  accuracy  Float?   // Added for performance (avoid joins)
  timeTaken Int?     // Added for performance (avoid joins)
  createdAt DateTime @default(now())

  test Test @relation(fields: [testId], references: [id], onDelete: Restrict)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([testId, userId])
  @@index([testId, score(sort: Desc), timeTaken(sort: Asc)])
}

model UserTopicStat {
  id      BigInt @id @default(autoincrement())
  userId  String
  topicId String

  attempts Int    @default(0)
  correct  Int    @default(0)
  wrong    Int    @default(0)
  accuracy Float?

  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Restrict)

  @@unique([userId, topicId])
  @@index([topicId])
}

model AuditLog {
  id         BigInt  @id @default(autoincrement())
  actorId    String?
  actorRole  Role?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
}

//
// BILLING
//

model Plan {
  id           String   @id @default(cuid())
  name         String
  price        Float
  durationDays Int
  description  String?
  features     String[] // e.g. ["Full mock tests", "Video solutions"]
  isPopular    Boolean  @default(false)
  badge        String? // e.g. "Best Value"

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  accesses      PlanAccess[]
  subscriptions Subscription[]
  payments      Payment[]
}

model PlanAccess {
  id       String  @id @default(cuid())
  planId   String
  // XOR constraint: exactly one of examId or seriesId must be set
  // Enforced via raw SQL migration: planaccess_exactly_one
  examId   String?
  seriesId String?

  plan   Plan        @relation(fields: [planId], references: [id], onDelete: Restrict)
  exam   Exam?       @relation(fields: [examId], references: [id], onDelete: Restrict)
  series TestSeries? @relation(fields: [seriesId], references: [id], onDelete: Restrict)

  @@index([planId, examId])
  @@index([planId, seriesId])
}

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  planId         String
  startAt        DateTime
  expiresAt      DateTime
  status         SubscriptionStatus
  paymentOrderId String? // Razorpay order ID (order_xxx)
  paymentId      String? // Razorpay payment ID after success

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  plan     Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments Payment[]

  @@index([userId, expiresAt])
}

model Payment {
  id                String        @id @default(cuid())
  subscriptionId    String?
  userId            String
  planId            String
  razorpayOrderId   String        @unique
  razorpayPaymentId String?
  razorpaySignature String?
  amount            Int // in paise (₹1 = 100 paise)
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  plan         Plan          @relation(fields: [planId], references: [id])
}

model AdminSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
